{
  "name": "@hopdrive/hotswap",
  "version": "0.1.0",
  "description": "Zero-config SPA update detection and notification system for React + MUI + Vite apps",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hopdrive/hotswap.git"
  },
  "homepage": "https://github.com/hopdrive/hotswap#readme",
  "bugs": {
    "url": "https://github.com/hopdrive/hotswap/issues"
  },
  "keywords": [
    "spa",
    "update",
    "hotswap",
    "version-check",
    "service-worker",
    "react",
    "vite",
    "mui",
    "toast",
    "notification"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./mui": {
      "types": "./dist/mui/index.d.ts",
      "import": "./dist/mui/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "generate-version-json": "./dist/cli/generate-version-json.js"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^5.0.0 || ^6.0.0",
    "@mui/material": "^5.0.0 || ^6.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@mui/material": {
      "optional": true
    },
    "@mui/icons-material": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@types/react": "^18.3.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "~5.6.2",
    "vite": "^7.3.1"
  }
}
